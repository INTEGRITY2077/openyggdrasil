{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openyggdrasil.local/contracts/support_bundle.v1.schema.json",
  "title": "OpenYggdrasil Support Bundle v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source_packet_id",
    "source_packet_type",
    "query_text",
    "facts",
    "source_paths"
  ],
  "allOf": [
    {
      "anyOf": [
        {
          "properties": {
            "source_paths": {
              "minItems": 1
            }
          }
        },
        {
          "properties": {
            "canonical_note": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "canonical_note"
          ]
        },
        {
          "properties": {
            "provenance_note": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "provenance_note"
          ]
        },
        {
          "properties": {
            "pathfinder_bundle": {
              "type": "object",
              "required": [
                "source_paths"
              ],
              "properties": {
                "source_paths": {
                  "minItems": 1
                }
              }
            }
          },
          "required": [
            "pathfinder_bundle"
          ]
        }
      ]
    }
  ],
  "properties": {
    "schema_version": {
      "const": "support_bundle.v1"
    },
    "source_packet_id": {
      "type": "string",
      "minLength": 1
    },
    "source_packet_type": {
      "type": "string",
      "minLength": 1
    },
    "query_text": {
      "type": "string",
      "minLength": 1
    },
    "topic": {
      "type": [
        "string",
        "null"
      ]
    },
    "human_summary": {
      "type": [
        "string",
        "null"
      ]
    },
    "facts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "source_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "graph_freshness": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "maxProperties": 0
        },
        {
          "$ref": "#/$defs/graph_freshness"
        }
      ]
    },
    "pathfinder_bundle": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "maxProperties": 0
        },
        {
          "$ref": "#/$defs/pathfinder_bundle"
        },
        {
          "$ref": "#/$defs/pathfinder_source_bundle"
        }
      ]
    },
    "decision_key": {
      "type": [
        "string",
        "null"
      ]
    },
    "mailbox_location": {
      "type": [
        "string",
        "null"
      ]
    },
    "proof_token": {
      "type": [
        "string",
        "null"
      ]
    },
    "rationale_code": {
      "type": [
        "string",
        "null"
      ]
    },
    "canonical_note": {
      "type": [
        "string",
        "null"
      ]
    },
    "community_note": {
      "type": [
        "string",
        "null"
      ]
    },
    "provenance_note": {
      "type": [
        "string",
        "null"
      ]
    },
    "community_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_ref": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "$defs": {
    "graph_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "reasons",
        "graph_query_used"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "fresh",
            "stale",
            "missing",
            "unknown"
          ]
        },
        "reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "graph_query_used": {
          "type": "boolean"
        }
      }
    },
    "pathfinder_bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "query_text",
        "anchor_type",
        "anchor_id",
        "topic_id",
        "episode_ids",
        "claim_ids",
        "page_ids",
        "source_paths",
        "support_facts",
        "bundle_mode",
        "generated_at"
      ],
      "properties": {
        "schema_version": {
          "const": "pathfinder.v1"
        },
        "query_text": {
          "type": "string",
          "minLength": 1
        },
        "anchor_type": {
          "type": "string",
          "enum": [
            "topic",
            "none"
          ]
        },
        "anchor_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "topic_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "anchor_title": {
          "type": [
            "string",
            "null"
          ]
        },
        "episode_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "claim_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "page_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "support_facts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "bundle_mode": {
          "type": "string",
          "enum": [
            "topic-page-latest-episodes",
            "topic-page-latest-episodes-with-semantic-edges",
            "topic-page-recent-origin",
            "unanchored"
          ]
        },
        "generated_at": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "pathfinder_source_bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "source_paths"
      ],
      "properties": {
        "schema_version": {
          "const": "pathfinder.v1"
        },
        "source_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
