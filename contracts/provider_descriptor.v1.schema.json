{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openyggdrasil.local/contracts/provider_descriptor.v1.schema.json",
  "title": "OpenYggdrasil Provider Descriptor v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "provider_id",
    "provider_profile",
    "provider_session_id",
    "session_uid",
    "adapter_mode",
    "generated_at",
    "generated_by",
    "workspace_root",
    "capabilities"
  ],
  "properties": {
    "schema_version": {
      "const": "provider_descriptor.v1"
    },
    "provider_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_profile": {
      "type": "string",
      "minLength": 1
    },
    "provider_session_id": {
      "type": "string",
      "minLength": 1
    },
    "session_uid": {
      "type": "string",
      "minLength": 1
    },
    "adapter_mode": {
      "type": "string",
      "enum": [
        "skill_generated"
      ]
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "generated_by": {
      "type": "string",
      "enum": [
        "yggdrasil-skill-bootstrap",
        "hermes-foreground-probe"
      ]
    },
    "workspace_root": {
      "type": "string",
      "minLength": 1
    },
    "capabilities": {
      "$ref": "#/$defs/capabilities"
    },
    "provider_extras": {
      "type": "object"
    }
  },
  "$defs": {
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "attachment",
        "turn_delta",
        "reverse_inbox"
      ],
      "properties": {
        "attachment": {
          "type": "boolean"
        },
        "turn_delta": {
          "type": "boolean"
        },
        "reverse_inbox": {
          "type": "boolean"
        },
        "background_reasoning": {
          "type": "boolean"
        },
        "background_reasoning_descriptor": {
          "$ref": "#/$defs/background_reasoning_descriptor"
        },
        "heartbeat": {
          "type": "boolean"
        }
      }
    },
    "background_reasoning_descriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capability",
        "provider_surface",
        "support_status",
        "live_proof_required",
        "completion_status",
        "invocation_surface",
        "task_id_prefix",
        "context_window_policy",
        "raw_session_policy",
        "credential_policy",
        "evidence_refs",
        "next_action"
      ],
      "properties": {
        "capability": {
          "const": "background_reasoning"
        },
        "provider_surface": {
          "type": "string",
          "enum": [
            "hermes_background_command",
            "unavailable"
          ]
        },
        "support_status": {
          "type": "string",
          "enum": [
            "unavailable",
            "adapted_candidate",
            "supported"
          ]
        },
        "live_proof_required": {
          "type": "boolean"
        },
        "completion_status": {
          "type": "string",
          "enum": [
            "not_proven",
            "live_proven",
            "unavailable"
          ]
        },
        "invocation_surface": {
          "type": "string",
          "enum": [
            "provider_owned_command_gateway",
            "none"
          ]
        },
        "task_id_prefix": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 16
        },
        "context_window_policy": {
          "type": "string",
          "enum": [
            "must_not_append_to_main_active_conversation",
            "not_applicable"
          ]
        },
        "raw_session_policy": {
          "type": "string",
          "enum": [
            "metadata_only_no_raw_session_copy",
            "not_applicable"
          ]
        },
        "credential_policy": {
          "const": "provider_owned_no_openyggdrasil_credentials"
        },
        "evidence_refs": {
          "type": "array",
          "maxItems": 12,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 700
          }
        },
        "next_action": {
          "type": "string",
          "minLength": 1,
          "maxLength": 180
        }
      }
    }
  }
}
