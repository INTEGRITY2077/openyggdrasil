{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openyggdrasil.local/contracts/mailbox_guard_result.v1.schema.json",
  "title": "OpenYggdrasil Mailbox Guard Result v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "verdict",
    "action",
    "reason_codes",
    "checked_at"
  ],
  "properties": {
    "schema_version": {
      "const": "mailbox_guard_result.v1"
    },
    "message_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "message_type": {
      "type": [
        "string",
        "null"
      ]
    },
    "verdict": {
      "type": "string",
      "enum": [
        "accept",
        "quarantine",
        "reject"
      ]
    },
    "action": {
      "type": "string",
      "enum": [
        "admit",
        "quarantine",
        "drop"
      ]
    },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "checked_at": {
      "type": "string",
      "format": "date-time"
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "profile": {
          "type": [
            "string",
            "null"
          ]
        },
        "session_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "topic": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
