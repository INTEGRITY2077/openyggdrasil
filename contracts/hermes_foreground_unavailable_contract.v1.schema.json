{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openyggdrasil.local/contracts/hermes_foreground_unavailable_contract.v1.schema.json",
  "title": "OpenYggdrasil Hermes Foreground Unavailable Contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "unavailable_id",
    "provider_id",
    "provider_profile",
    "provider_session_id",
    "unavailable_kind",
    "reason_code",
    "packaging_status_decision",
    "runner_outcome",
    "fault_domain",
    "openyggdrasil_runtime_failure",
    "fallback_policy",
    "fallback_path_status",
    "bootstrap_contract_status",
    "memory_roundtrip_contract_status",
    "live_foreground_claimed",
    "foreground_equivalent_relabel",
    "raw_transcript_copied",
    "raw_session_copied",
    "global_inbox_created",
    "doc_committed",
    "missing_dependency_refs",
    "evidence_refs",
    "next_action",
    "checked_at"
  ],
  "properties": {
    "schema_version": {
      "const": "hermes_foreground_unavailable_contract.v1"
    },
    "unavailable_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "provider_id": {
      "const": "hermes"
    },
    "provider_profile": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "maxLength": 120
    },
    "provider_session_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "maxLength": 180
    },
    "unavailable_kind": {
      "type": "string",
      "enum": [
        "provider_harness_dependency_missing",
        "live_foreground_surface_unavailable",
        "live_foreground_bootstrap_unavailable",
        "live_foreground_memory_roundtrip_unavailable",
        "live_foreground_unverifiable"
      ]
    },
    "reason_code": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180
    },
    "packaging_status_decision": {
      "const": "unavailable"
    },
    "runner_outcome": {
      "type": "string",
      "enum": [
        "foreground_probe_dependency_missing",
        "live_foreground_unavailable",
        "live_bootstrap_unavailable",
        "live_memory_roundtrip_unavailable",
        "live_foreground_unverifiable"
      ]
    },
    "fault_domain": {
      "type": "string",
      "enum": [
        "provider_harness",
        "provider_live_surface",
        "provider_capability"
      ]
    },
    "openyggdrasil_runtime_failure": {
      "const": false
    },
    "fallback_policy": {
      "type": "string",
      "enum": [
        "foreground_equivalent_contract",
        "typed_known_limitation",
        "manual_review"
      ]
    },
    "fallback_path_status": {
      "type": "string",
      "enum": [
        "foreground_equivalent_contract_available",
        "typed_known_limitation_available",
        "manual_review_available"
      ]
    },
    "bootstrap_contract_status": {
      "type": "string",
      "enum": [
        "available",
        "foreground_equivalent_passed",
        "unavailable"
      ]
    },
    "memory_roundtrip_contract_status": {
      "type": "string",
      "enum": [
        "foreground_equivalent_passed",
        "unavailable"
      ]
    },
    "live_foreground_claimed": {
      "const": false
    },
    "foreground_equivalent_relabel": {
      "const": false
    },
    "raw_transcript_copied": {
      "const": false
    },
    "raw_session_copied": {
      "const": false
    },
    "global_inbox_created": {
      "const": false
    },
    "doc_committed": {
      "const": false
    },
    "missing_dependency_refs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 700
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 700
      }
    },
    "next_action": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180
    },
    "checked_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
