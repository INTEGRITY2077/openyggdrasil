{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openyggdrasil.local/contracts/no_credential_prompt_regression_result.v1.schema.json",
  "title": "OpenYggdrasil No Credential Prompt Regression Result v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "regression_id",
    "status",
    "scanned_surface_count",
    "surface_results",
    "runtime_boundary_constraints",
    "explicit_false_flags",
    "prompt_attempt_count",
    "prompt_attempt_kinds",
    "credential_prompt_detected",
    "api_key_prompt_detected",
    "oauth_prompt_detected",
    "stored_credential_request_detected",
    "openyggdrasil_owned_credentials_required",
    "credential_prompted",
    "api_key_prompted",
    "oauth_prompted",
    "raw_session_copied",
    "foreground_context_appended",
    "source_refs",
    "next_action",
    "checked_at"
  ],
  "properties": {
    "schema_version": {
      "const": "no_credential_prompt_regression_result.v1"
    },
    "regression_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "status": {
      "type": "string",
      "enum": [
        "passed",
        "failed"
      ]
    },
    "scanned_surface_count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 64
    },
    "surface_results": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "surface_id",
          "status",
          "prompt_attempt_kinds",
          "explicit_false_flags"
        ],
        "properties": {
          "surface_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 160
          },
          "status": {
            "type": "string",
            "enum": [
              "passed",
              "failed"
            ]
          },
          "prompt_attempt_kinds": {
            "type": "array",
            "maxItems": 16,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "enum": [
                "credential_prompt",
                "api_key_prompt",
                "oauth_prompt",
                "stored_credential_request"
              ]
            }
          },
          "explicit_false_flags": {
            "type": "array",
            "maxItems": 16,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 80
            }
          }
        }
      }
    },
    "runtime_boundary_constraints": {
      "type": "array",
      "maxItems": 24,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 120
      }
    },
    "explicit_false_flags": {
      "type": "array",
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 80
      }
    },
    "prompt_attempt_count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 256
    },
    "prompt_attempt_kinds": {
      "type": "array",
      "maxItems": 8,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "credential_prompt",
          "api_key_prompt",
          "oauth_prompt",
          "stored_credential_request"
        ]
      }
    },
    "credential_prompt_detected": {
      "type": "boolean"
    },
    "api_key_prompt_detected": {
      "type": "boolean"
    },
    "oauth_prompt_detected": {
      "type": "boolean"
    },
    "stored_credential_request_detected": {
      "type": "boolean"
    },
    "openyggdrasil_owned_credentials_required": {
      "const": false
    },
    "credential_prompted": {
      "const": false
    },
    "api_key_prompted": {
      "const": false
    },
    "oauth_prompted": {
      "const": false
    },
    "raw_session_copied": {
      "const": false
    },
    "foreground_context_appended": {
      "const": false
    },
    "source_refs": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 700
      }
    },
    "next_action": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180
    },
    "checked_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
