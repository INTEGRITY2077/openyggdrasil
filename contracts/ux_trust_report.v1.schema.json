{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openyggdrasil.local/contracts/ux_trust_report.v1.schema.json",
  "title": "OpenYggdrasil UX Trust Report v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "report_id",
    "decision",
    "ux_trust_score",
    "chain_health_score",
    "mailbox_quality_score",
    "hermes_response_quality_score",
    "memory_visibility_score",
    "diagnosability_score",
    "live_foreground_status",
    "input_scorecard_ids",
    "zero_tolerance_failures",
    "failing_metrics",
    "checked_at"
  ],
  "properties": {
    "schema_version": {
      "const": "ux_trust_report.v1"
    },
    "report_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "decision": {
      "type": "string",
      "enum": [
        "green_passed",
        "red_captured"
      ]
    },
    "ux_trust_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 5
    },
    "chain_health_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5
    },
    "mailbox_quality_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5
    },
    "hermes_response_quality_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5
    },
    "memory_visibility_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5
    },
    "diagnosability_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5
    },
    "live_foreground_status": {
      "type": "string",
      "enum": [
        "live_proven",
        "typed_unavailable",
        "foreground_equivalent",
        "not_proven"
      ]
    },
    "input_scorecard_ids": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "chain_health",
        "mailbox_quality",
        "hermes_response_quality"
      ],
      "properties": {
        "chain_health": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "mailbox_quality": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "hermes_response_quality": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      }
    },
    "zero_tolerance_failures": {
      "type": "array",
      "maxItems": 16,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100,
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "failing_metrics": {
      "type": "array",
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100,
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "checked_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
