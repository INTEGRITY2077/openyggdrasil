{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openyggdrasil.local/contracts/provider_packaging_known_limitations_matrix.v1.schema.json",
  "title": "OpenYggdrasil Provider Packaging Known Limitations Matrix v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "matrix_id",
    "provider_order",
    "rows",
    "matrix_summary",
    "safety",
    "next_action",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "provider_packaging_known_limitations_matrix.v1"
    },
    "matrix_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "provider_order": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "hermes",
          "codex",
          "claude-code",
          "gemini-antigravity",
          "windsurf",
          "cursor",
          "openclaw-oas"
        ]
      }
    },
    "rows": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "items": {
        "$ref": "#/$defs/providerRow"
      }
    },
    "matrix_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "baseline_ready_count",
        "degraded_or_limited_count",
        "unsupported_count",
        "official_doc_recheck_required",
        "phase_close_review_next"
      ],
      "properties": {
        "baseline_ready_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 7
        },
        "degraded_or_limited_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 7
        },
        "unsupported_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 7
        },
        "official_doc_recheck_required": {
          "const": false
        },
        "phase_close_review_next": {
          "const": true
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "doc_committed",
        "raw_transcript_copied",
        "raw_session_copied",
        "global_inbox_created",
        "product_behavior_claimed",
        "provider_specific_contract_bypass",
        "phase5_memory_gates_weakened"
      ],
      "properties": {
        "doc_committed": {
          "const": false
        },
        "raw_transcript_copied": {
          "const": false
        },
        "raw_session_copied": {
          "const": false
        },
        "global_inbox_created": {
          "const": false
        },
        "product_behavior_claimed": {
          "const": false
        },
        "provider_specific_contract_bypass": {
          "const": false
        },
        "phase5_memory_gates_weakened": {
          "const": false
        }
      }
    },
    "next_action": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "providerRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_id",
        "provider_family",
        "support_level",
        "matrix_status",
        "deploy_surface_status",
        "deploy_target",
        "packaging_contract_ref",
        "provider_specific_smoke_status",
        "failure_mode",
        "clear_failure_instruction",
        "operator_instruction",
        "expected_contracts",
        "limitation_refs",
        "safety"
      ],
      "properties": {
        "provider_id": {
          "type": "string",
          "enum": [
            "hermes",
            "codex",
            "claude-code",
            "gemini-antigravity",
            "windsurf",
            "cursor",
            "openclaw-oas"
          ]
        },
        "provider_family": {
          "type": "string",
          "minLength": 1,
          "maxLength": 180
        },
        "support_level": {
          "type": "string",
          "enum": [
            "supported",
            "degraded",
            "limited",
            "unsupported"
          ]
        },
        "matrix_status": {
          "type": "string",
          "enum": [
            "baseline_ready",
            "typed_degrade_ready",
            "typed_limitations_only",
            "missing_surface_unsupported"
          ]
        },
        "deploy_surface_status": {
          "type": "string",
          "enum": [
            "profile_skill_sync_available",
            "provider_native_file_target_available",
            "provider_neutral_only",
            "missing_surface"
          ]
        },
        "deploy_target": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 700
        },
        "packaging_contract_ref": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 180
        },
        "provider_specific_smoke_status": {
          "type": "string",
          "enum": [
            "passed",
            "typed_unavailable",
            "not_claimed",
            "not_available"
          ]
        },
        "failure_mode": {
          "type": "string",
          "enum": [
            "none",
            "typed_degrade",
            "known_limitation",
            "unsupported_missing_surface"
          ]
        },
        "clear_failure_instruction": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "operator_instruction": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "expected_contracts": {
          "type": "array",
          "minItems": 4,
          "maxItems": 8,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "provider_descriptor.v1",
              "session_attachment.v1",
              "inbox_binding.v1",
              "turn_delta.v1",
              "hermes_foreground_unavailable_contract.v1",
              "codex_provider_packaging_baseline.v1",
              "claude_code_provider_packaging_baseline.v1",
              "antigravity_provider_packaging_baseline.v1"
            ]
          }
        },
        "limitation_refs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 12,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 700
          }
        },
        "safety": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "doc_committed",
            "raw_transcript_copied",
            "raw_session_copied",
            "global_inbox_created",
            "product_behavior_claimed",
            "provider_specific_contract_bypass",
            "phase5_memory_gates_weakened"
          ],
          "properties": {
            "doc_committed": {
              "const": false
            },
            "raw_transcript_copied": {
              "const": false
            },
            "raw_session_copied": {
              "const": false
            },
            "global_inbox_created": {
              "const": false
            },
            "product_behavior_claimed": {
              "const": false
            },
            "provider_specific_contract_bypass": {
              "const": false
            },
            "phase5_memory_gates_weakened": {
              "const": false
            }
          }
        }
      }
    }
  }
}
