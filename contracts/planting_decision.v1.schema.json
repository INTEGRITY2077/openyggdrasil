{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openyggdrasil.local/contracts/planting_decision.v1.schema.json",
  "title": "OpenYggdrasil Planting Decision v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "planting_id",
    "seed_id",
    "candidate_id",
    "continent_id",
    "continent_key",
    "topic_id",
    "topic_title",
    "bed_id",
    "planting_target_kind",
    "planting_target_key",
    "planting_status",
    "quarantine_status",
    "growth_decision",
    "pruning_decision",
    "planting_reason",
    "planted_at"
  ],
  "properties": {
    "schema_version": {
      "const": "planting_decision.v1"
    },
    "planting_id": {
      "type": "string",
      "minLength": 1
    },
    "seed_id": {
      "type": "string",
      "minLength": 1
    },
    "candidate_id": {
      "type": "string",
      "minLength": 1
    },
    "continent_id": {
      "type": "string",
      "minLength": 1
    },
    "continent_key": {
      "type": "string",
      "minLength": 1
    },
    "topic_id": {
      "type": "string",
      "minLength": 1
    },
    "topic_title": {
      "type": "string",
      "minLength": 1
    },
    "bed_id": {
      "type": "string",
      "minLength": 1
    },
    "planting_target_kind": {
      "type": "string",
      "enum": [
        "topic_page"
      ]
    },
    "planting_target_key": {
      "type": "string",
      "minLength": 1
    },
    "planting_status": {
      "type": "string",
      "enum": [
        "planted",
        "quarantined"
      ]
    },
    "quarantine_status": {
      "type": "string",
      "enum": [
        "clean",
        "quarantined"
      ]
    },
    "growth_decision": {
      "type": "string",
      "enum": [
        "allow_growth"
      ]
    },
    "pruning_decision": {
      "type": "string",
      "enum": [
        "keep"
      ]
    },
    "planting_reason": {
      "type": "string",
      "minLength": 1
    },
    "planted_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
