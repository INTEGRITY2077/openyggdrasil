{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openyggdrasil.local/contracts/support_bundle_delivery_policy.v1.schema.json",
  "title": "OpenYggdrasil Support Bundle Delivery Policy v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "policy_decision_id",
    "decision",
    "reason_codes",
    "dedup_fingerprint",
    "existing_message_id",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "support_bundle_delivery_policy.v1"
    },
    "policy_decision_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "decision": {
      "type": "string",
      "enum": [
        "create",
        "reuse",
        "regenerate",
        "reject"
      ]
    },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 120,
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "dedup_fingerprint": {
      "type": "string",
      "minLength": 64,
      "maxLength": 64
    },
    "existing_message_id": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 128
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
