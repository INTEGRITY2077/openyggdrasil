{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openyggdrasil.local/contracts/physical_multiturn_session_artifact_bundle.v1.schema.json",
  "title": "OpenYggdrasil Physical Multiturn Session Artifact Bundle v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_bundle_id",
    "provider_name",
    "provider_profile",
    "session_kind",
    "session_ref",
    "session_started_at",
    "session_finished_at",
    "session_summary",
    "turn_count",
    "user_message_count",
    "assistant_message_count",
    "skill_attachment_ref",
    "safe_transcript_ref",
    "raw_transcript_included",
    "mailbox_receipt_refs",
    "knowledge_forest_delta_refs",
    "graphify_snapshot_refs",
    "reasoning_lease_isolation_refs",
    "typed_unavailable_surfaces",
    "rerun_condition",
    "evidence_required",
    "claim_scope",
    "decision",
    "readiness_state",
    "checked_at"
  ],
  "properties": {
    "schema_version": {
      "const": "physical_multiturn_session_artifact_bundle.v1"
    },
    "artifact_bundle_id": {
      "$ref": "#/$defs/id"
    },
    "provider_name": {
      "const": "hermes"
    },
    "provider_profile": {
      "$ref": "#/$defs/id"
    },
    "session_kind": {
      "type": "string",
      "enum": [
        "physical_live",
        "typed_unavailable_not_live_proven"
      ]
    },
    "session_ref": {
      "$ref": "#/$defs/refOrNull"
    },
    "session_started_at": {
      "$ref": "#/$defs/timestampOrNull"
    },
    "session_finished_at": {
      "$ref": "#/$defs/timestampOrNull"
    },
    "session_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "turn_count": {
      "type": "integer",
      "minimum": 0
    },
    "user_message_count": {
      "type": "integer",
      "minimum": 0
    },
    "assistant_message_count": {
      "type": "integer",
      "minimum": 0
    },
    "skill_attachment_ref": {
      "$ref": "#/$defs/refOrNull"
    },
    "safe_transcript_ref": {
      "$ref": "#/$defs/refOrNull"
    },
    "raw_transcript_included": {
      "const": false
    },
    "mailbox_receipt_refs": {
      "$ref": "#/$defs/refList"
    },
    "knowledge_forest_delta_refs": {
      "$ref": "#/$defs/refList"
    },
    "graphify_snapshot_refs": {
      "$ref": "#/$defs/refList"
    },
    "reasoning_lease_isolation_refs": {
      "$ref": "#/$defs/refList"
    },
    "typed_unavailable_surfaces": {
      "type": "array",
      "maxItems": 8,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/surface"
      }
    },
    "rerun_condition": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 120,
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        {
          "type": "null"
        }
      ]
    },
    "evidence_required": {
      "type": "array",
      "maxItems": 16,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 120,
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "claim_scope": {
      "type": "string",
      "enum": [
        "e2e1_physical_session_only",
        "full_live_e2e_artifact_bundle_candidate",
        "typed_unavailable_not_live_proven",
        "not_claimable"
      ]
    },
    "decision": {
      "type": "string",
      "enum": [
        "e2e1_physical_session_artifact_valid",
        "typed_unavailable_not_live_proven",
        "red_captured"
      ]
    },
    "readiness_state": {
      "type": "string",
      "enum": [
        "ready_for_e2e2",
        "not_ready"
      ]
    },
    "checked_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "refOrNull": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 360
        },
        {
          "type": "null"
        }
      ]
    },
    "timestampOrNull": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        {
          "type": "null"
        }
      ]
    },
    "refList": {
      "type": "array",
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 360
      }
    },
    "surface": {
      "type": "string",
      "enum": [
        "physical_hermes_multiturn_session",
        "knowledge_forest_delta",
        "graphify_snapshot",
        "mailbox_receipt",
        "reasoning_lease_isolation"
      ]
    }
  }
}
