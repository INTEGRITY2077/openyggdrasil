{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openyggdrasil.local/contracts/source_ref_resolution_result.v1.schema.json",
  "title": "OpenYggdrasil Source Ref Resolution Result v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "resolution_id",
    "signal_id",
    "status",
    "reason_codes",
    "source_ref",
    "source_ref_token",
    "next_action",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "source_ref_resolution_result.v1"
    },
    "resolution_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "signal_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "status": {
      "type": "string",
      "enum": [
        "resolved",
        "reject",
        "unavailable"
      ]
    },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 80,
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "source_ref": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "kind",
        "path_hint",
        "range_hint",
        "symlink_hint"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "path_hint": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "range_hint": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "symlink_hint": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 512
        }
      }
    },
    "source_ref_token": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 700
    },
    "next_action": {
      "type": "string",
      "enum": [
        "continue_admission",
        "reject_signal",
        "defer_until_source_available"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
