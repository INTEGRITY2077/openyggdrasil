{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Episode Semantic Edges Verdict",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "supports",
    "supersedes",
    "contradicts",
    "reason_labels",
    "summary",
    "evaluation_mode",
    "evaluated_at"
  ],
  "properties": {
    "schema_version": {
      "const": "episode_semantic_edges.v1"
    },
    "supports": {
      "type": "array",
      "items": { "type": "string" }
    },
    "supersedes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "contradicts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "reason_labels": {
      "type": "array",
      "items": { "type": "string" }
    },
    "summary": {
      "type": "string"
    },
    "evaluation_mode": {
      "type": "string"
    },
    "evaluated_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
