{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openyggdrasil.local/contracts/hermes_provider_packaging_baseline.v1.schema.json",
  "title": "OpenYggdrasil Hermes Provider Packaging Baseline v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "baseline_id",
    "provider_id",
    "provider_profile",
    "provider_session_id",
    "provider_family",
    "packaging_status",
    "install_path",
    "activation_path",
    "bootstrap_command",
    "skill_name",
    "skill_category",
    "provider_descriptor_contract",
    "session_attachment_contract",
    "inbox_binding_contract",
    "turn_delta_contract",
    "expected_yggdrasil_tree",
    "local_smoke_status",
    "live_foreground_status",
    "typed_unavailable_contract",
    "known_limitations",
    "safety",
    "next_action",
    "checked_at"
  ],
  "properties": {
    "schema_version": {
      "const": "hermes_provider_packaging_baseline.v1"
    },
    "baseline_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "provider_id": {
      "const": "hermes"
    },
    "provider_profile": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "provider_session_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180
    },
    "provider_family": {
      "const": "Hermes"
    },
    "packaging_status": {
      "const": "baseline_ready_with_typed_live_foreground_unavailable"
    },
    "install_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 700
    },
    "activation_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 700
    },
    "bootstrap_command": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "skill_name": {
      "const": "openyggdrasil-foreground-probe"
    },
    "skill_category": {
      "const": "autonomous-ai-agents"
    },
    "provider_descriptor_contract": {
      "const": "provider_descriptor.v1"
    },
    "session_attachment_contract": {
      "const": "session_attachment.v1"
    },
    "inbox_binding_contract": {
      "const": "inbox_binding.v1"
    },
    "turn_delta_contract": {
      "const": "turn_delta.v1"
    },
    "expected_yggdrasil_tree": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_descriptor",
        "session_attachment",
        "inbox_binding",
        "turn_delta",
        "session_inbox"
      ],
      "properties": {
        "provider_descriptor": {
          "type": "string",
          "pattern": "^\\.yggdrasil/providers/hermes/.+/provider_descriptor\\.v1\\.json$"
        },
        "session_attachment": {
          "type": "string",
          "pattern": "^\\.yggdrasil/providers/hermes/.+/session_attachment\\.v1\\.json$"
        },
        "inbox_binding": {
          "type": "string",
          "pattern": "^\\.yggdrasil/providers/hermes/.+/inbox_binding\\.v1\\.json$"
        },
        "turn_delta": {
          "type": "string",
          "pattern": "^\\.yggdrasil/providers/hermes/.+/turn_delta\\.v1\\.jsonl$"
        },
        "session_inbox": {
          "type": "string",
          "pattern": "^\\.yggdrasil/inbox/hermes/.+\\.jsonl$"
        }
      }
    },
    "local_smoke_status": {
      "type": "string",
      "enum": [
        "provider_bootstrap_contract_passed",
        "not_run"
      ]
    },
    "live_foreground_status": {
      "const": "typed_unavailable"
    },
    "typed_unavailable_contract": {
      "const": "hermes_foreground_unavailable_contract.v1"
    },
    "known_limitations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 500
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "doc_committed",
        "raw_transcript_copied",
        "raw_session_copied",
        "global_inbox_created",
        "live_foreground_claimed",
        "foreground_equivalent_relabel",
        "phase5_memory_gates_weakened"
      ],
      "properties": {
        "doc_committed": {
          "const": false
        },
        "raw_transcript_copied": {
          "const": false
        },
        "raw_session_copied": {
          "const": false
        },
        "global_inbox_created": {
          "const": false
        },
        "live_foreground_claimed": {
          "const": false
        },
        "foreground_equivalent_relabel": {
          "const": false
        },
        "phase5_memory_gates_weakened": {
          "const": false
        }
      }
    },
    "next_action": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180
    },
    "checked_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
