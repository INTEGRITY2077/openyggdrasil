{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openyggdrasil.local/contracts/provider_descriptor.v1.schema.json",
  "title": "OpenYggdrasil Provider Descriptor v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "provider_id",
    "provider_profile",
    "provider_session_id",
    "session_uid",
    "adapter_mode",
    "generated_at",
    "generated_by",
    "workspace_root",
    "capabilities"
  ],
  "properties": {
    "schema_version": {
      "const": "provider_descriptor.v1"
    },
    "provider_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_profile": {
      "type": "string",
      "minLength": 1
    },
    "provider_session_id": {
      "type": "string",
      "minLength": 1
    },
    "session_uid": {
      "type": "string",
      "minLength": 1
    },
    "adapter_mode": {
      "type": "string",
      "enum": [
        "skill_generated"
      ]
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "generated_by": {
      "type": "string",
      "enum": [
        "yggdrasil-skill-bootstrap",
        "hermes-foreground-probe"
      ]
    },
    "workspace_root": {
      "type": "string",
      "minLength": 1
    },
    "capabilities": {
      "$ref": "#/$defs/capabilities"
    },
    "provider_extras": {
      "type": "object"
    }
  },
  "$defs": {
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "attachment",
        "turn_delta",
        "reverse_inbox"
      ],
      "properties": {
        "attachment": {
          "type": "boolean"
        },
        "turn_delta": {
          "type": "boolean"
        },
        "reverse_inbox": {
          "type": "boolean"
        },
        "heartbeat": {
          "type": "boolean"
        }
      }
    }
  }
}
