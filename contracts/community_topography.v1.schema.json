{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://integrity2077.local/openyggdrasil/community_topography.v1.schema.json",
  "title": "Community Topography v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "community_topography_id",
    "topography_id",
    "community_id",
    "community_key",
    "community_title",
    "continent_id",
    "continent_key",
    "member_topic_ids",
    "community_note_relative_path",
    "bridge_keys",
    "bridge_count",
    "bridge_status",
    "topography_status",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "const": "community_topography.v1"
    },
    "community_topography_id": {
      "type": "string",
      "minLength": 1
    },
    "topography_id": {
      "type": "string",
      "minLength": 1
    },
    "community_id": {
      "type": "string",
      "minLength": 1
    },
    "community_key": {
      "type": "string",
      "minLength": 1
    },
    "community_title": {
      "type": "string",
      "minLength": 1
    },
    "continent_id": {
      "type": "string",
      "minLength": 1
    },
    "continent_key": {
      "type": "string",
      "minLength": 1
    },
    "member_topic_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "community_note_relative_path": {
      "type": "string",
      "minLength": 1
    },
    "bridge_keys": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "bridge_count": {
      "type": "integer",
      "minimum": 0
    },
    "bridge_status": {
      "type": "string",
      "enum": [
        "no_bridges"
      ]
    },
    "topography_status": {
      "type": "string",
      "enum": [
        "isolated"
      ]
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
