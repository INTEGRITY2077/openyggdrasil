{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openyggdrasil.local/contracts/cultivated_decision.v1.schema.json",
  "title": "OpenYggdrasil Cultivated Decision v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "cultivation_id",
    "seed_id",
    "candidate_id",
    "topic_id",
    "topic_title",
    "page_id",
    "canonical_relative_path",
    "provenance_relative_path",
    "canonical_note_path",
    "provenance_note_path",
    "claim_id",
    "decision_text",
    "support_fact",
    "cultivated_at"
  ],
  "properties": {
    "schema_version": {
      "const": "cultivated_decision.v1"
    },
    "cultivation_id": {
      "type": "string",
      "minLength": 1
    },
    "seed_id": {
      "type": "string",
      "minLength": 1
    },
    "candidate_id": {
      "type": "string",
      "minLength": 1
    },
    "topic_id": {
      "type": "string",
      "minLength": 1
    },
    "topic_title": {
      "type": "string",
      "minLength": 1
    },
    "page_id": {
      "type": "string",
      "minLength": 1
    },
    "canonical_relative_path": {
      "type": "string",
      "minLength": 1
    },
    "provenance_relative_path": {
      "type": "string",
      "minLength": 1
    },
    "canonical_note_path": {
      "type": "string",
      "minLength": 1
    },
    "provenance_note_path": {
      "type": "string",
      "minLength": 1
    },
    "claim_id": {
      "type": "string",
      "minLength": 1
    },
    "decision_text": {
      "type": "string",
      "minLength": 1
    },
    "support_fact": {
      "type": "string",
      "minLength": 1
    },
    "source_rel": {
      "type": "string"
    },
    "cultivated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
