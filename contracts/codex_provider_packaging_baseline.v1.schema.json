{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openyggdrasil.local/contracts/codex_provider_packaging_baseline.v1.schema.json",
  "title": "OpenYggdrasil Codex Provider Packaging Baseline v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "baseline_id",
    "provider_id",
    "provider_profile",
    "provider_session_id",
    "provider_family",
    "packaging_status",
    "provider_native_deploy_target_status",
    "deploy_tool_surface",
    "activation_path",
    "degrade_reason",
    "provider_descriptor_contract",
    "session_attachment_contract",
    "inbox_binding_contract",
    "turn_delta_contract",
    "expected_yggdrasil_tree",
    "local_smoke_status",
    "known_limitations",
    "safety",
    "next_action",
    "checked_at"
  ],
  "properties": {
    "schema_version": {
      "const": "codex_provider_packaging_baseline.v1"
    },
    "baseline_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "provider_id": {
      "const": "codex"
    },
    "provider_profile": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "provider_session_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180
    },
    "provider_family": {
      "const": "Codex"
    },
    "packaging_status": {
      "const": "degrade_ready_without_provider_native_deploy_target"
    },
    "provider_native_deploy_target_status": {
      "const": "unsupported_provider_for_file_deployment"
    },
    "deploy_tool_surface": {
      "const": "runtime/attachments/deploy_skill.py"
    },
    "activation_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "degrade_reason": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "provider_descriptor_contract": {
      "const": "provider_descriptor.v1"
    },
    "session_attachment_contract": {
      "const": "session_attachment.v1"
    },
    "inbox_binding_contract": {
      "const": "inbox_binding.v1"
    },
    "turn_delta_contract": {
      "const": "turn_delta.v1"
    },
    "expected_yggdrasil_tree": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_descriptor",
        "session_attachment",
        "inbox_binding",
        "turn_delta",
        "session_inbox"
      ],
      "properties": {
        "provider_descriptor": {
          "type": "string",
          "pattern": "^\\.yggdrasil/providers/codex/.+/provider_descriptor\\.v1\\.json$"
        },
        "session_attachment": {
          "type": "string",
          "pattern": "^\\.yggdrasil/providers/codex/.+/session_attachment\\.v1\\.json$"
        },
        "inbox_binding": {
          "type": "string",
          "pattern": "^\\.yggdrasil/providers/codex/.+/inbox_binding\\.v1\\.json$"
        },
        "turn_delta": {
          "type": "string",
          "pattern": "^\\.yggdrasil/providers/codex/.+/turn_delta\\.v1\\.jsonl$"
        },
        "session_inbox": {
          "type": "string",
          "pattern": "^\\.yggdrasil/inbox/codex/.+\\.jsonl$"
        }
      }
    },
    "local_smoke_status": {
      "type": "string",
      "enum": [
        "provider_bootstrap_contract_passed",
        "not_run"
      ]
    },
    "known_limitations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 500
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "doc_committed",
        "raw_transcript_copied",
        "raw_session_copied",
        "global_inbox_created",
        "provider_native_deploy_target_claimed",
        "phase5_memory_gates_weakened"
      ],
      "properties": {
        "doc_committed": {
          "const": false
        },
        "raw_transcript_copied": {
          "const": false
        },
        "raw_session_copied": {
          "const": false
        },
        "global_inbox_created": {
          "const": false
        },
        "provider_native_deploy_target_claimed": {
          "const": false
        },
        "phase5_memory_gates_weakened": {
          "const": false
        }
      }
    },
    "next_action": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180
    },
    "checked_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
