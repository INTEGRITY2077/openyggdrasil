{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openyggdrasil.local/contracts/decision_candidate.v1.schema.json",
  "title": "OpenYggdrasil Decision Candidate v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "candidate_id",
    "dedup_key",
    "provider_id",
    "provider_profile",
    "provider_session_id",
    "session_uid",
    "turn_start",
    "turn_end",
    "surface_summary",
    "trigger_reason",
    "decision_text",
    "rationale",
    "alternatives_rejected",
    "stability_state",
    "reason_labels",
    "confidence_score",
    "origin_locator",
    "generated_at"
  ],
  "properties": {
    "schema_version": {
      "const": "decision_candidate.v1"
    },
    "candidate_id": {
      "type": "string",
      "minLength": 1
    },
    "dedup_key": {
      "type": "string",
      "minLength": 1
    },
    "provider_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_profile": {
      "type": "string",
      "minLength": 1
    },
    "provider_session_id": {
      "type": "string",
      "minLength": 1
    },
    "session_uid": {
      "type": "string",
      "minLength": 1
    },
    "turn_start": {
      "type": "integer",
      "minimum": 1
    },
    "turn_end": {
      "type": "integer",
      "minimum": 1
    },
    "surface_summary": {
      "type": "string",
      "minLength": 1
    },
    "trigger_reason": {
      "type": "string",
      "minLength": 1
    },
    "decision_text": {
      "type": "string",
      "minLength": 1
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "alternatives_rejected": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "stability_state": {
      "type": "string",
      "enum": [
        "provisional",
        "stable",
        "superseding"
      ]
    },
    "topic_hint": {
      "type": [
        "string",
        "null"
      ]
    },
    "reason_labels": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence_score": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "source_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "origin_locator": {
      "type": "object",
      "minProperties": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
