{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openyggdrasil.local/contracts/mailbox_delivery_hermes_consumption.v1.schema.json",
  "title": "OpenYggdrasil Mailbox Delivery Hermes Consumption v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "consumption_proof_id",
    "source_graphify_snapshot_id",
    "source_delta_id",
    "source_artifact_bundle_id",
    "provider_name",
    "provider_profile",
    "session_ref",
    "support_bundle_fingerprint",
    "delivery_receipt",
    "hermes_consumption_receipt",
    "stale_decoy_rejection_receipts",
    "safe_evidence_pointer_count",
    "raw_transcript_included",
    "mailbox_delivery_proven",
    "hermes_consumption_proven",
    "stale_decoy_rejection_proven",
    "reasoning_lease_isolation_refs",
    "typed_unavailable_surfaces",
    "rerun_condition",
    "evidence_required",
    "claim_scope",
    "decision",
    "readiness_state",
    "checked_at"
  ],
  "properties": {
    "schema_version": {
      "const": "mailbox_delivery_hermes_consumption.v1"
    },
    "consumption_proof_id": {
      "$ref": "#/$defs/id"
    },
    "source_graphify_snapshot_id": {
      "$ref": "#/$defs/id"
    },
    "source_delta_id": {
      "$ref": "#/$defs/id"
    },
    "source_artifact_bundle_id": {
      "$ref": "#/$defs/id"
    },
    "provider_name": {
      "const": "hermes"
    },
    "provider_profile": {
      "$ref": "#/$defs/id"
    },
    "session_ref": {
      "$ref": "#/$defs/ref"
    },
    "support_bundle_fingerprint": {
      "$ref": "#/$defs/hashOrNull"
    },
    "delivery_receipt": {
      "anyOf": [
        {
          "$ref": "#/$defs/mailboxDeliveryReceipt"
        },
        {
          "type": "null"
        }
      ]
    },
    "hermes_consumption_receipt": {
      "anyOf": [
        {
          "$ref": "#/$defs/hermesConsumptionReceipt"
        },
        {
          "type": "null"
        }
      ]
    },
    "stale_decoy_rejection_receipts": {
      "type": "array",
      "maxItems": 16,
      "items": {
        "$ref": "#/$defs/staleDecoyRejectionReceipt"
      }
    },
    "safe_evidence_pointer_count": {
      "type": "integer",
      "minimum": 0
    },
    "raw_transcript_included": {
      "const": false
    },
    "mailbox_delivery_proven": {
      "type": "boolean"
    },
    "hermes_consumption_proven": {
      "type": "boolean"
    },
    "stale_decoy_rejection_proven": {
      "type": "boolean"
    },
    "reasoning_lease_isolation_refs": {
      "$ref": "#/$defs/stringRefs"
    },
    "typed_unavailable_surfaces": {
      "type": "array",
      "maxItems": 8,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/surface"
      }
    },
    "rerun_condition": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 140,
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        {
          "type": "null"
        }
      ]
    },
    "evidence_required": {
      "type": "array",
      "maxItems": 16,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 140,
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "claim_scope": {
      "type": "string",
      "enum": [
        "e2e4_mailbox_delivery_consumption_only",
        "full_live_e2e_mailbox_candidate",
        "typed_unavailable_not_live_proven",
        "not_claimable"
      ]
    },
    "decision": {
      "type": "string",
      "enum": [
        "e2e4_mailbox_delivery_consumption_valid",
        "typed_unavailable_not_live_proven",
        "red_captured"
      ]
    },
    "readiness_state": {
      "type": "string",
      "enum": [
        "ready_for_e2e5",
        "not_ready"
      ]
    },
    "checked_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 520
    },
    "hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "hashOrNull": {
      "anyOf": [
        {
          "$ref": "#/$defs/hash"
        },
        {
          "type": "null"
        }
      ]
    },
    "stringRefs": {
      "type": "array",
      "maxItems": 64,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/ref"
      }
    },
    "surface": {
      "type": "string",
      "enum": [
        "mailbox_delivery",
        "hermes_consumption",
        "stale_decoy_rejection",
        "reasoning_lease_isolation"
      ]
    },
    "mailboxGuardResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "message_id",
        "message_type",
        "verdict",
        "action",
        "reason_codes",
        "checked_at",
        "scope"
      ],
      "properties": {
        "schema_version": {
          "const": "mailbox_guard_result.v1"
        },
        "message_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "message_type": {
          "type": [
            "string",
            "null"
          ]
        },
        "verdict": {
          "enum": [
            "accept",
            "quarantine",
            "reject"
          ]
        },
        "action": {
          "enum": [
            "admit",
            "quarantine",
            "drop"
          ]
        },
        "reason_codes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "checked_at": {
          "type": "string",
          "format": "date-time"
        },
        "scope": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "provider_id": {
              "type": [
                "string",
                "null"
              ]
            },
            "profile": {
              "type": [
                "string",
                "null"
              ]
            },
            "session_id": {
              "type": [
                "string",
                "null"
              ]
            },
            "topic": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        }
      }
    },
    "supportBundle": {
      "type": "object",
      "minProperties": 1
    },
    "mailboxDeliveryReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "delivery_status",
        "provider_id",
        "provider_profile",
        "provider_session_id",
        "message_id",
        "inbox_path",
        "support_bundle_ref",
        "support_bundle_fingerprint",
        "support_bundle",
        "guard_result"
      ],
      "properties": {
        "schema_version": {
          "const": "mailbox_delivery_receipt.v1"
        },
        "delivery_status": {
          "enum": [
            "delivered",
            "reused"
          ]
        },
        "provider_id": {
          "const": "hermes"
        },
        "provider_profile": {
          "$ref": "#/$defs/id"
        },
        "provider_session_id": {
          "$ref": "#/$defs/id"
        },
        "message_id": {
          "$ref": "#/$defs/id"
        },
        "inbox_path": {
          "$ref": "#/$defs/ref"
        },
        "support_bundle_ref": {
          "$ref": "#/$defs/ref"
        },
        "support_bundle_fingerprint": {
          "$ref": "#/$defs/hash"
        },
        "support_bundle": {
          "$ref": "#/$defs/supportBundle"
        },
        "guard_result": {
          "$ref": "#/$defs/mailboxGuardResult"
        }
      }
    },
    "hermesConsumptionReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "consumption_status",
        "provider_id",
        "provider_profile",
        "provider_session_id",
        "response_ref",
        "consumed_message_id",
        "support_bundle_fingerprint",
        "consumed_support_bundle",
        "used_memory_refs",
        "safe_evidence_pointers",
        "rejected_memory",
        "raw_transcript_included",
        "response_quality_scorecard"
      ],
      "properties": {
        "schema_version": {
          "const": "hermes_consumption_receipt.v1"
        },
        "consumption_status": {
          "const": "consumed"
        },
        "provider_id": {
          "const": "hermes"
        },
        "provider_profile": {
          "$ref": "#/$defs/id"
        },
        "provider_session_id": {
          "$ref": "#/$defs/id"
        },
        "response_ref": {
          "$ref": "#/$defs/ref"
        },
        "consumed_message_id": {
          "$ref": "#/$defs/id"
        },
        "support_bundle_fingerprint": {
          "$ref": "#/$defs/hash"
        },
        "consumed_support_bundle": {
          "$ref": "#/$defs/supportBundle"
        },
        "used_memory_refs": {
          "$ref": "#/$defs/stringRefs"
        },
        "safe_evidence_pointers": {
          "$ref": "#/$defs/stringRefs"
        },
        "rejected_memory": {
          "type": "array",
          "maxItems": 32,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "memory_ref",
              "reason_codes"
            ],
            "properties": {
              "memory_ref": {
                "$ref": "#/$defs/ref"
              },
              "reason_codes": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        },
        "raw_transcript_included": {
          "const": false
        },
        "response_quality_scorecard": {
          "type": "object",
          "minProperties": 1
        }
      }
    },
    "staleDecoyRejectionReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_role",
        "message_id",
        "guard_result"
      ],
      "properties": {
        "candidate_role": {
          "enum": [
            "stale_memory",
            "decoy_memory"
          ]
        },
        "message_id": {
          "$ref": "#/$defs/id"
        },
        "guard_result": {
          "$ref": "#/$defs/mailboxGuardResult"
        }
      }
    }
  }
}
