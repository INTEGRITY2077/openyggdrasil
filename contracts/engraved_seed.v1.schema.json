{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openyggdrasil.local/contracts/engraved_seed.v1.schema.json",
  "title": "OpenYggdrasil Engraved Seed v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "seed_id",
    "verdict_id",
    "candidate_id",
    "continent_key",
    "continent_id",
    "continent_title",
    "topic_key",
    "topic_id",
    "topic_title",
    "page_id",
    "canonical_relative_path",
    "episode_id",
    "seed_identity_key",
    "planting_target_kind",
    "planting_target_hint",
    "planting_ready",
    "integrity_status",
    "integrity_reason",
    "provenance_ring",
    "surface_summary",
    "trigger_reason",
    "decision_text",
    "rationale",
    "stability_state",
    "engraved_at"
  ],
  "properties": {
    "schema_version": {
      "const": "engraved_seed.v1"
    },
    "seed_id": {
      "type": "string",
      "minLength": 1
    },
    "verdict_id": {
      "type": "string",
      "minLength": 1
    },
    "candidate_id": {
      "type": "string",
      "minLength": 1
    },
    "continent_key": {
      "type": "string",
      "minLength": 1
    },
    "continent_id": {
      "type": "string",
      "minLength": 1
    },
    "continent_title": {
      "type": "string",
      "minLength": 1
    },
    "topic_key": {
      "type": "string",
      "minLength": 1
    },
    "topic_id": {
      "type": "string",
      "minLength": 1
    },
    "topic_title": {
      "type": "string",
      "minLength": 1
    },
    "page_id": {
      "type": "string",
      "minLength": 1
    },
    "canonical_relative_path": {
      "type": "string",
      "minLength": 1
    },
    "episode_id": {
      "type": "string",
      "minLength": 1
    },
    "seed_identity_key": {
      "type": "string",
      "minLength": 1
    },
    "planting_target_kind": {
      "type": "string",
      "enum": [
        "topic_page"
      ]
    },
    "planting_target_hint": {
      "type": "string",
      "minLength": 1
    },
    "planting_ready": {
      "type": "boolean"
    },
    "integrity_status": {
      "type": "string",
      "enum": [
        "clean",
        "review_needed"
      ]
    },
    "integrity_reason": {
      "type": "string",
      "minLength": 1
    },
    "provenance_ring": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_id",
        "provider_profile",
        "provider_session_id",
        "session_uid",
        "turn_range"
      ],
      "properties": {
        "provider_id": {
          "type": "string",
          "minLength": 1
        },
        "provider_profile": {
          "type": "string",
          "minLength": 1
        },
        "provider_session_id": {
          "type": "string",
          "minLength": 1
        },
        "session_uid": {
          "type": "string",
          "minLength": 1
        },
        "turn_range": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "integer"
          }
        },
        "source_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "origin_locator": {
          "type": "object"
        }
      }
    },
    "surface_summary": {
      "type": "string"
    },
    "trigger_reason": {
      "type": "string"
    },
    "decision_text": {
      "type": "string",
      "minLength": 1
    },
    "rationale": {
      "type": "string"
    },
    "alternatives_rejected": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "stability_state": {
      "type": "string",
      "enum": [
        "provisional",
        "stable",
        "superseding"
      ]
    },
    "source_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "origin_locator": {
      "type": "object"
    },
    "engraved_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
