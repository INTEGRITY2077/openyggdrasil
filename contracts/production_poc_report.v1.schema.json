{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openyggdrasil.local/contracts/production_poc_report.v1.schema.json",
  "title": "OpenYggdrasil Production POC Report v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "report_id",
    "decision",
    "readiness_state",
    "scenario_count",
    "green_scenario_count",
    "not_implemented_scenario_count",
    "must_pass_safety_cases_pass_rate",
    "must_pass_memory_visibility_cases_pass_rate",
    "quality_cases_pass_rate",
    "raw_provider_session_copy_count",
    "public_forbidden_tracked_path_count",
    "doc_or_ignored_artifact_dependency_count",
    "history_core_public_track_hygiene_state",
    "live_provider_readiness",
    "live_provider_rerun_condition",
    "live_provider_evidence_required",
    "ux_trust_decision",
    "foreground_live_comparison_decision",
    "failing_metrics",
    "residual_risks",
    "checked_at"
  ],
  "properties": {
    "schema_version": {
      "const": "production_poc_report.v1"
    },
    "report_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "decision": {
      "type": "string",
      "enum": [
        "green_passed",
        "red_captured"
      ]
    },
    "readiness_state": {
      "type": "string",
      "enum": [
        "ready",
        "not_ready",
        "blocked"
      ]
    },
    "scenario_count": {
      "type": "integer",
      "minimum": 0
    },
    "green_scenario_count": {
      "type": "integer",
      "minimum": 0
    },
    "not_implemented_scenario_count": {
      "type": "integer",
      "minimum": 0
    },
    "must_pass_safety_cases_pass_rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "must_pass_memory_visibility_cases_pass_rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "quality_cases_pass_rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "raw_provider_session_copy_count": {
      "type": "integer",
      "minimum": 0
    },
    "public_forbidden_tracked_path_count": {
      "type": "integer",
      "minimum": 0
    },
    "doc_or_ignored_artifact_dependency_count": {
      "type": "integer",
      "minimum": 0
    },
    "history_core_public_track_hygiene_state": {
      "type": "string",
      "enum": [
        "sanitized_verified",
        "blocked_by_existing_tracked_leakage",
        "not_checked"
      ]
    },
    "live_provider_readiness": {
      "type": "string",
      "enum": [
        "live_proven",
        "typed_unavailable_not_live_proven",
        "not_implemented",
        "not_claimable"
      ]
    },
    "live_provider_rerun_condition": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "maxLength": 100,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "live_provider_evidence_required": {
      "type": "array",
      "maxItems": 8,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100,
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "ux_trust_decision": {
      "type": "string",
      "enum": [
        "green_passed",
        "red_captured"
      ]
    },
    "foreground_live_comparison_decision": {
      "type": "string",
      "enum": [
        "green_passed",
        "red_captured"
      ]
    },
    "failing_metrics": {
      "type": "array",
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100,
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "residual_risks": {
      "type": "array",
      "maxItems": 16,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 240
      }
    },
    "checked_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
