{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openyggdrasil.local/contracts/role_split_integration_result.v1.schema.json",
  "title": "OpenYggdrasil Role Split Integration Result v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "integration_id",
    "chain_result_id",
    "status",
    "role_sequence",
    "required_artifacts",
    "authority_checks",
    "failure_reasons",
    "reason_codes",
    "checked_at"
  ],
  "properties": {
    "schema_version": {
      "const": "role_split_integration_result.v1"
    },
    "integration_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "chain_result_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "status": {
      "type": "string",
      "enum": [
        "passed",
        "failed"
      ]
    },
    "role_sequence": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "items": {
        "type": "string",
        "enum": [
          "distiller",
          "evaluator",
          "amundsen",
          "seedkeeper",
          "gardener",
          "map_maker",
          "postman"
        ]
      }
    },
    "required_artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_candidate_batch",
        "evaluator_verdict",
        "evaluator_amundsen_handoff",
        "admission_verdict",
        "amundsen_nursery_handoff",
        "seedkeeper_segment",
        "nursery_composition_input",
        "engraved_seed",
        "planting_decision",
        "gardener_routing_decision",
        "cultivated_decision",
        "map_topography",
        "postman_handoff"
      ],
      "properties": {
        "decision_candidate_batch": {
          "type": "boolean"
        },
        "evaluator_verdict": {
          "type": "boolean"
        },
        "evaluator_amundsen_handoff": {
          "type": "boolean"
        },
        "admission_verdict": {
          "type": "boolean"
        },
        "amundsen_nursery_handoff": {
          "type": "boolean"
        },
        "seedkeeper_segment": {
          "type": "boolean"
        },
        "nursery_composition_input": {
          "type": "boolean"
        },
        "engraved_seed": {
          "type": "boolean"
        },
        "planting_decision": {
          "type": "boolean"
        },
        "gardener_routing_decision": {
          "type": "boolean"
        },
        "cultivated_decision": {
          "type": "boolean"
        },
        "map_topography": {
          "type": "boolean"
        },
        "postman_handoff": {
          "type": "boolean"
        }
      }
    },
    "authority_checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "distiller_no_semantic_filter",
        "evaluator_semantic_worth_owner",
        "amundsen_route_only",
        "seedkeeper_source_ref_only",
        "nursery_composed_input_ready",
        "gardener_forest_routing_only",
        "map_maker_placement_only",
        "postman_delivery_ready"
      ],
      "properties": {
        "distiller_no_semantic_filter": {
          "type": "boolean"
        },
        "evaluator_semantic_worth_owner": {
          "type": "boolean"
        },
        "amundsen_route_only": {
          "type": "boolean"
        },
        "seedkeeper_source_ref_only": {
          "type": "boolean"
        },
        "nursery_composed_input_ready": {
          "type": "boolean"
        },
        "gardener_forest_routing_only": {
          "type": "boolean"
        },
        "map_maker_placement_only": {
          "type": "boolean"
        },
        "postman_delivery_ready": {
          "type": "boolean"
        }
      }
    },
    "failure_reasons": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 120,
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100,
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "checked_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
