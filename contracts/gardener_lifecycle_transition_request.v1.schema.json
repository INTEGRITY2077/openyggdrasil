{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openyggdrasil.local/contracts/gardener_lifecycle_transition_request.v1.schema.json",
  "title": "OpenYggdrasil Gardener Lifecycle Transition Request v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "transition_request_id",
    "request_kind",
    "request_status",
    "requested_lifecycle_state",
    "active_record_ref",
    "successor_record_id",
    "candidate_ref",
    "source_refs",
    "provenance",
    "invalidated_by",
    "supersession_reason",
    "proposed_transition",
    "gate_metadata",
    "gardener_authority",
    "candidate_authority",
    "lifecycle_review_required",
    "canonical_authority",
    "canonical_write_status",
    "direct_canonical_mutation_status",
    "vault_mutation_allowed",
    "physical_delete_allowed",
    "traceability_preserved",
    "reason_codes",
    "requested_at"
  ],
  "properties": {
    "schema_version": {
      "const": "gardener_lifecycle_transition_request.v1"
    },
    "transition_request_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "request_kind": {
      "const": "gardener_lifecycle_transition_request"
    },
    "request_status": {
      "const": "pending_gate_review"
    },
    "requested_lifecycle_state": {
      "type": "string",
      "enum": [
        "SUPERSEDED",
        "STALE"
      ]
    },
    "active_record_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lifecycle_record_id",
        "canonical_record_id",
        "lifecycle_state",
        "canonical_ref",
        "valid_from",
        "archive_trace_refs"
      ],
      "properties": {
        "lifecycle_record_id": {
          "type": "string",
          "minLength": 1
        },
        "canonical_record_id": {
          "type": "string",
          "minLength": 1
        },
        "lifecycle_state": {
          "const": "ACTIVE"
        },
        "canonical_ref": {
          "type": "object",
          "minProperties": 1
        },
        "valid_from": {
          "type": "string",
          "format": "date-time"
        },
        "archive_trace_refs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 48,
          "items": {
            "type": "object",
            "minProperties": 1
          }
        }
      }
    },
    "successor_record_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "candidate_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_kind",
        "candidate_id",
        "candidate_status",
        "evidence_ref"
      ],
      "properties": {
        "candidate_kind": {
          "type": "string",
          "enum": [
            "vault_promotion_request",
            "contradiction",
            "lint",
            "simplicity"
          ]
        },
        "candidate_id": {
          "type": "string",
          "minLength": 1
        },
        "candidate_status": {
          "const": "proposed"
        },
        "evidence_ref": {
          "type": "object",
          "minProperties": 1
        }
      }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 24,
      "items": {
        "type": "object",
        "minProperties": 1
      }
    },
    "provenance": {
      "type": "object",
      "minProperties": 1
    },
    "invalidated_by": {
      "type": "object",
      "minProperties": 1
    },
    "supersession_reason": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "proposed_transition": {
      "type": "object",
      "minProperties": 1
    },
    "gate_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_gate",
        "lifecycle_review_gate",
        "direct_mutation_gate"
      ],
      "properties": {
        "candidate_gate": {
          "const": "proposal_only"
        },
        "lifecycle_review_gate": {
          "const": "pending_lifecycle_review"
        },
        "direct_mutation_gate": {
          "const": "not_authorized_by_request"
        }
      }
    },
    "gardener_authority": {
      "const": "lifecycle_transition_request_only"
    },
    "candidate_authority": {
      "const": "proposal_only"
    },
    "lifecycle_review_required": {
      "const": true
    },
    "canonical_authority": {
      "const": "not_this_contract"
    },
    "canonical_write_status": {
      "const": "not_written"
    },
    "direct_canonical_mutation_status": {
      "const": "not_mutated"
    },
    "vault_mutation_allowed": {
      "const": false
    },
    "physical_delete_allowed": {
      "const": false
    },
    "traceability_preserved": {
      "const": true
    },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 24,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100,
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "requested_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "requested_lifecycle_state": {
            "const": "SUPERSEDED"
          }
        }
      },
      "then": {
        "properties": {
          "successor_record_id": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "requested_lifecycle_state": {
            "const": "STALE"
          }
        }
      },
      "then": {
        "properties": {
          "successor_record_id": {
            "const": null
          }
        }
      }
    }
  ]
}
