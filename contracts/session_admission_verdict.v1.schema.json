{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openyggdrasil.local/contracts/session_admission_verdict.v1.schema.json",
  "title": "OpenYggdrasil Session Admission Verdict v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "verdict_id",
    "signal_id",
    "provider_id",
    "provider_profile",
    "provider_session_id",
    "session_uid",
    "verdict",
    "reason_codes",
    "source_ref_resolution",
    "next_role",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "session_admission_verdict.v1"
    },
    "verdict_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "signal_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "provider_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "provider_profile": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "provider_session_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180
    },
    "session_uid": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "verdict": {
      "type": "string",
      "enum": [
        "accept",
        "defer",
        "reject"
      ]
    },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 80,
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "source_ref_resolution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "resolution_id",
        "signal_id",
        "status",
        "reason_codes",
        "source_ref",
        "source_ref_token",
        "next_action",
        "created_at"
      ],
      "properties": {
        "schema_version": {
          "const": "source_ref_resolution_result.v1"
        },
        "resolution_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "signal_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "status": {
          "type": "string",
          "enum": [
            "resolved",
            "reject",
            "unavailable"
          ]
        },
        "reason_codes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 12,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80,
            "pattern": "^[A-Za-z0-9._:-]+$"
          }
        },
        "source_ref": {
          "type": [
            "object",
            "null"
          ]
        },
        "source_ref_token": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 700
        },
        "next_action": {
          "type": "string",
          "enum": [
            "continue_admission",
            "reject_signal",
            "defer_until_source_available"
          ]
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "next_role": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "seedkeeper",
        "review_queue",
        null
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
