{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openyggdrasil.local/contracts/effort_aware_gardener_worthiness.v1.schema.json",
  "title": "OpenYggdrasil Effort Aware Gardener Worthiness v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "worthiness_id",
    "worthiness_status",
    "promotion_request_id",
    "candidate_id",
    "provider_id",
    "provider_profile",
    "session_uid",
    "requested_owner",
    "source_refs",
    "evaluator_verdict_ref",
    "confidence",
    "effort_assessment",
    "gate_metadata",
    "promotion_review_required",
    "canonical_authority",
    "canonical_write_status",
    "vault_mutation_allowed",
    "reason_codes",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "effort_aware_gardener_worthiness.v1"
    },
    "worthiness_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "worthiness_status": {
      "type": "string",
      "enum": [
        "ready_for_promotion_review",
        "deferred_for_effort_review"
      ]
    },
    "promotion_request_id": {
      "type": "string",
      "minLength": 1
    },
    "candidate_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_profile": {
      "type": "string",
      "minLength": 1
    },
    "session_uid": {
      "type": "string",
      "minLength": 1
    },
    "requested_owner": {
      "type": "string",
      "enum": [
        "gardener",
        "vault_promotion_review"
      ]
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 24,
      "items": {
        "type": "object",
        "minProperties": 1
      }
    },
    "evaluator_verdict_ref": {
      "type": "object",
      "minProperties": 1
    },
    "confidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "worthiness_score",
        "confidence_score"
      ],
      "properties": {
        "worthiness_score": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "confidence_score": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        }
      }
    },
    "effort_assessment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "effort_status",
        "requested_effort",
        "applied_effort",
        "actual_effort_estimate",
        "minimum_required_effort",
        "effort_status_accepted",
        "requested_effort_known",
        "applied_effort_known",
        "actual_effort_known",
        "applied_effort_meets_minimum",
        "actual_effort_meets_minimum",
        "applied_effort_meets_requested",
        "downgrade_detected"
      ],
      "properties": {
        "effort_status": {
          "type": "string",
          "enum": [
            "verified",
            "declared",
            "downgraded",
            "unavailable",
            "unknown"
          ]
        },
        "requested_effort": {
          "$ref": "#/$defs/effortLevel"
        },
        "applied_effort": {
          "$ref": "#/$defs/effortLevel"
        },
        "actual_effort_estimate": {
          "$ref": "#/$defs/effortLevel"
        },
        "minimum_required_effort": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "xhigh"
          ]
        },
        "effort_status_accepted": {
          "type": "boolean"
        },
        "requested_effort_known": {
          "type": "boolean"
        },
        "applied_effort_known": {
          "type": "boolean"
        },
        "actual_effort_known": {
          "type": "boolean"
        },
        "applied_effort_meets_minimum": {
          "type": "boolean"
        },
        "actual_effort_meets_minimum": {
          "type": "boolean"
        },
        "applied_effort_meets_requested": {
          "type": "boolean"
        },
        "downgrade_detected": {
          "type": "boolean"
        }
      }
    },
    "gate_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "promotion_request_gate",
        "effort_status_gate",
        "actual_effort_gate",
        "canonical_write_gate"
      ],
      "properties": {
        "promotion_request_gate": {
          "const": "vault_promotion_request_required"
        },
        "effort_status_gate": {
          "const": "verified_required"
        },
        "actual_effort_gate": {
          "const": "minimum_required_before_review"
        },
        "canonical_write_gate": {
          "const": "not_authorized_by_worthiness"
        }
      }
    },
    "promotion_review_required": {
      "const": true
    },
    "canonical_authority": {
      "const": "not_this_contract"
    },
    "canonical_write_status": {
      "const": "not_written"
    },
    "vault_mutation_allowed": {
      "const": false
    },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 24,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100,
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "effortLevel": {
      "type": "string",
      "enum": [
        "unknown",
        "low",
        "medium",
        "high",
        "xhigh"
      ]
    }
  }
}
