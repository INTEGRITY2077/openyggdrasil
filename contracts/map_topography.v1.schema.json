{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://integrity2077.local/openyggdrasil/map_topography.v1.schema.json",
  "title": "Map Topography v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "topography_id",
    "cultivation_id",
    "planting_id",
    "continent_id",
    "continent_key",
    "topic_id",
    "topic_title",
    "page_id",
    "canonical_relative_path",
    "bed_id",
    "planting_target_kind",
    "planting_target_key",
    "routing_mode",
    "topography_status",
    "adjacency_keys",
    "bridge_count",
    "map_updated_at"
  ],
  "properties": {
    "schema_version": {
      "const": "map_topography.v1"
    },
    "topography_id": {
      "type": "string",
      "minLength": 1
    },
    "cultivation_id": {
      "type": "string",
      "minLength": 1
    },
    "planting_id": {
      "type": "string",
      "minLength": 1
    },
    "continent_id": {
      "type": "string",
      "minLength": 1
    },
    "continent_key": {
      "type": "string",
      "minLength": 1
    },
    "topic_id": {
      "type": "string",
      "minLength": 1
    },
    "topic_title": {
      "type": "string",
      "minLength": 1
    },
    "page_id": {
      "type": "string",
      "minLength": 1
    },
    "canonical_relative_path": {
      "type": "string",
      "minLength": 1
    },
    "bed_id": {
      "type": "string",
      "minLength": 1
    },
    "planting_target_kind": {
      "type": "string",
      "minLength": 1
    },
    "planting_target_key": {
      "type": "string",
      "minLength": 1
    },
    "routing_mode": {
      "type": "string",
      "enum": [
        "topic_page_only"
      ]
    },
    "topography_status": {
      "type": "string",
      "enum": [
        "aligned"
      ]
    },
    "adjacency_keys": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "bridge_count": {
      "type": "integer",
      "minimum": 0
    },
    "map_updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
