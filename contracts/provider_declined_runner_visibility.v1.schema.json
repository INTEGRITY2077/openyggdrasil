{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openyggdrasil.local/contracts/provider_declined_runner_visibility.v1.schema.json",
  "title": "OpenYggdrasil Provider Declined Runner Visibility v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "visibility_id",
    "lease_request_id",
    "provider_id",
    "provider_profile",
    "provider_session_id",
    "source_lease_status",
    "runner_visibility_status",
    "runner_stop_status",
    "reason_code",
    "fault_domain",
    "fallback_path_status",
    "provider_declined_visible",
    "decline_reason_preserved",
    "generic_failure_collapsed",
    "provider_decline_hidden_as_generic_failure",
    "openyggdrasil_runtime_failure",
    "credential_prompted",
    "oauth_prompted",
    "raw_session_copied",
    "foreground_context_appended",
    "source_refs",
    "next_action",
    "checked_at"
  ],
  "properties": {
    "schema_version": {
      "const": "provider_declined_runner_visibility.v1"
    },
    "visibility_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "lease_request_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "provider_profile": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "provider_session_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "source_lease_status": {
      "type": "string",
      "enum": [
        "completed",
        "declined",
        "unavailable",
        "failed",
        "fallback_used"
      ]
    },
    "runner_visibility_status": {
      "type": "string",
      "enum": [
        "provider_declined",
        "provider_unavailable",
        "provider_timeout",
        "provider_cancelled",
        "result_unavailable",
        "handoff_blocked",
        "handoff_unavailable",
        "effort_below_minimum",
        "effort_unverifiable",
        "lease_security_unavailable",
        "fallback_used",
        "completed",
        "failed_unknown"
      ]
    },
    "runner_stop_status": {
      "type": "string",
      "enum": [
        "stopped",
        "fallback",
        "completed"
      ]
    },
    "reason_code": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180
    },
    "fault_domain": {
      "type": "string",
      "enum": [
        "provider",
        "provider_result",
        "handoff_gate",
        "effort_policy",
        "lease_security",
        "fallback",
        "completed",
        "unknown"
      ]
    },
    "fallback_path_status": {
      "type": "string",
      "enum": [
        "deterministic_base_path_available",
        "local_worker_available",
        "manual_review_available",
        "fallback_policy_unavailable",
        "not_applicable"
      ]
    },
    "provider_declined_visible": {
      "type": "boolean"
    },
    "decline_reason_preserved": {
      "type": "boolean"
    },
    "generic_failure_collapsed": {
      "const": false
    },
    "provider_decline_hidden_as_generic_failure": {
      "const": false
    },
    "openyggdrasil_runtime_failure": {
      "const": false
    },
    "credential_prompted": {
      "const": false
    },
    "oauth_prompted": {
      "const": false
    },
    "raw_session_copied": {
      "const": false
    },
    "foreground_context_appended": {
      "const": false
    },
    "source_refs": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 700
      }
    },
    "next_action": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180
    },
    "checked_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
