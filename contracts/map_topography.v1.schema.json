{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://integrity2077.local/openyggdrasil/map_topography.v1.schema.json",
  "title": "Map Topography v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "topography_id",
    "cultivation_id",
    "planting_id",
    "continent_id",
    "continent_key",
    "topic_id",
    "topic_title",
    "page_id",
    "canonical_relative_path",
    "bed_id",
    "planting_target_kind",
    "planting_target_key",
    "routing_mode",
    "topography_status",
    "map_maker_authority",
    "semantic_worth_authority",
    "category_authority",
    "bridge_topology_authority",
    "category_source",
    "placement_source",
    "category_integrity_status",
    "bridge_creation_allowed",
    "amundsen_handoff_id",
    "gardener_routing_id",
    "adjacency_keys",
    "bridge_count",
    "map_updated_at"
  ],
  "properties": {
    "schema_version": {
      "const": "map_topography.v1"
    },
    "topography_id": {
      "type": "string",
      "minLength": 1
    },
    "cultivation_id": {
      "type": "string",
      "minLength": 1
    },
    "planting_id": {
      "type": "string",
      "minLength": 1
    },
    "continent_id": {
      "type": "string",
      "minLength": 1
    },
    "continent_key": {
      "type": "string",
      "minLength": 1
    },
    "topic_id": {
      "type": "string",
      "minLength": 1
    },
    "topic_title": {
      "type": "string",
      "minLength": 1
    },
    "page_id": {
      "type": "string",
      "minLength": 1
    },
    "canonical_relative_path": {
      "type": "string",
      "minLength": 1
    },
    "bed_id": {
      "type": "string",
      "minLength": 1
    },
    "planting_target_kind": {
      "type": "string",
      "minLength": 1
    },
    "planting_target_key": {
      "type": "string",
      "minLength": 1
    },
    "routing_mode": {
      "type": "string",
      "enum": [
        "topic_page_only"
      ]
    },
    "topography_status": {
      "type": "string",
      "enum": [
        "aligned"
      ]
    },
    "map_maker_authority": {
      "type": "string",
      "enum": [
        "placement_only"
      ]
    },
    "semantic_worth_authority": {
      "type": "string",
      "enum": [
        "not_map_maker"
      ]
    },
    "category_authority": {
      "type": "string",
      "enum": [
        "not_map_maker"
      ]
    },
    "bridge_topology_authority": {
      "type": "string",
      "enum": [
        "not_map_maker"
      ]
    },
    "category_source": {
      "type": "string",
      "enum": [
        "amundsen_nursery_handoff",
        "planting_decision"
      ]
    },
    "placement_source": {
      "type": "string",
      "enum": [
        "gardener_routing_decision",
        "cultivated_decision"
      ]
    },
    "category_integrity_status": {
      "type": "string",
      "enum": [
        "verified_against_amundsen_handoff",
        "legacy_planting_source_unverified"
      ]
    },
    "bridge_creation_allowed": {
      "const": false
    },
    "amundsen_handoff_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "gardener_routing_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "adjacency_keys": {
      "type": "array",
      "maxItems": 0,
      "items": {
        "type": "string"
      }
    },
    "bridge_count": {
      "type": "integer",
      "const": 0
    },
    "map_updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
