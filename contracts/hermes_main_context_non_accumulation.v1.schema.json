{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openyggdrasil.local/contracts/hermes_main_context_non_accumulation.v1.schema.json",
  "title": "OpenYggdrasil Hermes Main Context Non-Accumulation Proof v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "proof_id",
    "provider_id",
    "provider_profile",
    "provider_session_id",
    "proof_status",
    "foreground_append_status",
    "evidence_mode",
    "reason_codes",
    "observed_surfaces",
    "live_history_diff_available",
    "static_reference_non_append_marker_present",
    "worker_prompts_appended",
    "worker_traces_appended",
    "raw_tool_outputs_appended",
    "lease_result_payloads_appended",
    "raw_worker_prompt_copied",
    "raw_worker_trace_copied",
    "raw_tool_output_copied",
    "raw_lease_result_payload_copied",
    "bounded_preview_used",
    "digest_used",
    "source_ref_used",
    "blocked_attempt_kinds",
    "source_refs",
    "next_action",
    "checked_at"
  ],
  "properties": {
    "schema_version": {
      "const": "hermes_main_context_non_accumulation.v1"
    },
    "proof_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "provider_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_profile": {
      "type": "string",
      "minLength": 1
    },
    "provider_session_id": {
      "type": "string",
      "minLength": 1
    },
    "proof_status": {
      "type": "string",
      "enum": [
        "static_reference_proven",
        "live_history_diff_proven",
        "typed_unavailable",
        "blocked_unsafe_surface"
      ]
    },
    "foreground_append_status": {
      "type": "string",
      "enum": [
        "not_appended",
        "typed_unavailable",
        "blocked"
      ]
    },
    "evidence_mode": {
      "type": "string",
      "enum": [
        "static_reference_marker",
        "live_history_diff",
        "typed_unavailable"
      ]
    },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 120,
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "observed_surfaces": {
      "type": "array",
      "maxItems": 12,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "typed_gateway_result_surface",
          "bounded_preview",
          "digest",
          "source_ref",
          "task_ref",
          "explicit_unavailable",
          "provider_state_metadata_ref",
          "static_reference_marker"
        ]
      }
    },
    "live_history_diff_available": {
      "type": "boolean"
    },
    "static_reference_non_append_marker_present": {
      "type": "boolean"
    },
    "worker_prompts_appended": {
      "const": false
    },
    "worker_traces_appended": {
      "const": false
    },
    "raw_tool_outputs_appended": {
      "const": false
    },
    "lease_result_payloads_appended": {
      "const": false
    },
    "raw_worker_prompt_copied": {
      "const": false
    },
    "raw_worker_trace_copied": {
      "const": false
    },
    "raw_tool_output_copied": {
      "const": false
    },
    "raw_lease_result_payload_copied": {
      "const": false
    },
    "bounded_preview_used": {
      "type": "boolean"
    },
    "digest_used": {
      "type": "boolean"
    },
    "source_ref_used": {
      "type": "boolean"
    },
    "blocked_attempt_kinds": {
      "type": "array",
      "maxItems": 8,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "foreground_context_append",
          "raw_worker_prompt_copy",
          "raw_worker_trace_copy",
          "raw_tool_output_copy",
          "raw_lease_result_payload_copy",
          "missing_bounded_result_policy"
        ]
      }
    },
    "source_refs": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 700
      }
    },
    "next_action": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180
    },
    "checked_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
