{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openyggdrasil.local/contracts/provider_runtime_integrity_result.v1.schema.json",
  "title": "OpenYggdrasil Provider Runtime Integrity Result v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "integrity_id",
    "signal_id",
    "provider_id",
    "provider_profile",
    "provider_session_id",
    "session_uid",
    "status",
    "admission_allowed",
    "reason_codes",
    "runtime_event_labels",
    "recovery_actions",
    "evidence_refs",
    "next_action",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "provider_runtime_integrity_result.v1"
    },
    "integrity_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "signal_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "provider_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "provider_profile": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "provider_session_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180
    },
    "session_uid": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "recovered",
        "quarantine",
        "reject"
      ]
    },
    "admission_allowed": {
      "type": "boolean"
    },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 80,
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "runtime_event_labels": {
      "type": "array",
      "maxItems": 16,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 80,
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "recovery_actions": {
      "type": "array",
      "maxItems": 16,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 80,
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "path_hint"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "provider_session_source_ref",
              "provider_runtime_event",
              "provider_snapshot",
              "local_source_sot",
              "upstream_source_sot",
              "test_artifact"
            ]
          },
          "path_hint": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512
          },
          "range_hint": {
            "type": [
              "string",
              "null"
            ],
            "maxLength": 120
          },
          "commit_ref": {
            "type": [
              "string",
              "null"
            ],
            "maxLength": 80
          },
          "source_url": {
            "type": [
              "string",
              "null"
            ],
            "maxLength": 512
          }
        }
      }
    },
    "next_action": {
      "type": "string",
      "enum": [
        "run_session_admission_gate",
        "retry_after_stable_turn",
        "manual_review",
        "reject_signal"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
