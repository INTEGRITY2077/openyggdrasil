{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openyggdrasil.local/contracts/hermes_background_unavailable_contract.v1.schema.json",
  "title": "OpenYggdrasil Hermes Background Unavailable Contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "unavailable_id",
    "provider_id",
    "provider_profile",
    "provider_session_id",
    "unavailable_kind",
    "reason_code",
    "lease_status_decision",
    "runner_outcome",
    "fault_domain",
    "openyggdrasil_runtime_failure",
    "fallback_policy",
    "fallback_path_status",
    "deterministic_base_path_preserved",
    "manual_review_path_preserved",
    "captured_task_ref",
    "worker_ref",
    "sandbox_or_security_status",
    "credential_prompted",
    "oauth_prompted",
    "raw_transcript_copied",
    "raw_session_copied",
    "state_db_result_harvested",
    "foreground_context_appended",
    "source_refs",
    "next_action",
    "checked_at"
  ],
  "properties": {
    "schema_version": {
      "const": "hermes_background_unavailable_contract.v1"
    },
    "unavailable_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "provider_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "provider_profile": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "provider_session_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "unavailable_kind": {
      "type": "string",
      "enum": [
        "unsupported_provider",
        "provider_declined",
        "provider_timeout",
        "provider_cancelled",
        "no_visible_result",
        "handoff_gate_blocked",
        "handoff_gate_unavailable",
        "effort_below_minimum",
        "effort_unknown_unverifiable",
        "sandbox_security_unavailable"
      ]
    },
    "reason_code": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180
    },
    "lease_status_decision": {
      "type": "string",
      "enum": [
        "declined",
        "unavailable",
        "failed"
      ]
    },
    "runner_outcome": {
      "type": "string",
      "enum": [
        "provider_unavailable",
        "provider_declined",
        "provider_timeout",
        "provider_cancelled",
        "result_unavailable",
        "handoff_blocked",
        "handoff_unavailable",
        "effort_below_minimum",
        "effort_unverifiable",
        "lease_security_unavailable"
      ]
    },
    "fault_domain": {
      "type": "string",
      "enum": [
        "provider",
        "provider_result",
        "handoff_gate",
        "effort_policy",
        "lease_security"
      ]
    },
    "openyggdrasil_runtime_failure": {
      "const": false
    },
    "fallback_policy": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "deterministic_base_path",
        "local_worker",
        "manual_review",
        null
      ]
    },
    "fallback_path_status": {
      "type": "string",
      "enum": [
        "deterministic_base_path_available",
        "local_worker_available",
        "manual_review_available",
        "fallback_policy_unavailable"
      ]
    },
    "deterministic_base_path_preserved": {
      "type": "boolean"
    },
    "manual_review_path_preserved": {
      "type": "boolean"
    },
    "captured_task_ref": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^bg_[A-Za-z0-9][A-Za-z0-9_.:-]*$"
    },
    "worker_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "maxLength": 260
    },
    "sandbox_or_security_status": {
      "type": "string",
      "enum": [
        "not_applicable",
        "unavailable"
      ]
    },
    "credential_prompted": {
      "const": false
    },
    "oauth_prompted": {
      "const": false
    },
    "raw_transcript_copied": {
      "const": false
    },
    "raw_session_copied": {
      "const": false
    },
    "state_db_result_harvested": {
      "const": false
    },
    "foreground_context_appended": {
      "const": false
    },
    "source_refs": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 700
      }
    },
    "next_action": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180
    },
    "checked_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
