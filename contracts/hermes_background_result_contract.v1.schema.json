{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openyggdrasil.local/contracts/hermes_background_result_contract.v1.schema.json",
  "title": "OpenYggdrasil Hermes Background Result Contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "result_contract_id",
    "provider_id",
    "provider_profile",
    "provider_session_id",
    "capture_id",
    "captured_task_ref",
    "result_gate_status",
    "result_gate_reason_code",
    "lease_status_decision",
    "result_source_ref",
    "worker_ref",
    "result_preview",
    "preview_max_chars",
    "result_digest_sha256",
    "confidence_score",
    "token_usage",
    "duration_ms",
    "tool_call_count",
    "requested_effort",
    "applied_effort",
    "normalized_effort",
    "effort_status",
    "actual_effort_estimate",
    "raw_transcript_copied",
    "raw_session_copied",
    "state_db_result_harvested",
    "foreground_context_appended",
    "source_refs",
    "next_action",
    "checked_at"
  ],
  "properties": {
    "schema_version": {
      "const": "hermes_background_result_contract.v1"
    },
    "result_contract_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "provider_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_profile": {
      "type": "string",
      "minLength": 1
    },
    "provider_session_id": {
      "type": "string",
      "minLength": 1
    },
    "capture_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "captured_task_ref": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^bg_[A-Za-z0-9][A-Za-z0-9_.:-]*$"
    },
    "result_gate_status": {
      "type": "string",
      "enum": [
        "allowed",
        "blocked",
        "unavailable"
      ]
    },
    "result_gate_reason_code": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "maxLength": 180
    },
    "lease_status_decision": {
      "type": "string",
      "enum": [
        "completed",
        "failed",
        "unavailable",
        "fallback_used"
      ]
    },
    "result_source_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "maxLength": 700
    },
    "worker_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "maxLength": 260
    },
    "result_preview": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 512
    },
    "preview_max_chars": {
      "type": "integer",
      "minimum": 1,
      "maximum": 512
    },
    "result_digest_sha256": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[a-f0-9]{64}$"
    },
    "confidence_score": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "token_usage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_tokens",
        "output_tokens",
        "total_tokens"
      ],
      "properties": {
        "input_tokens": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "output_tokens": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "total_tokens": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        }
      }
    },
    "duration_ms": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "tool_call_count": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "requested_effort": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "maxLength": 80
    },
    "applied_effort": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "maxLength": 80
    },
    "normalized_effort": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "low",
        "medium",
        "high",
        "xhigh",
        null
      ]
    },
    "effort_status": {
      "type": "string",
      "enum": [
        "verified",
        "accepted",
        "downgraded",
        "below_minimum",
        "unknown",
        "unavailable",
        "unverified"
      ]
    },
    "actual_effort_estimate": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "maxLength": 120
    },
    "raw_transcript_copied": {
      "const": false
    },
    "raw_session_copied": {
      "const": false
    },
    "state_db_result_harvested": {
      "const": false
    },
    "foreground_context_appended": {
      "const": false
    },
    "source_refs": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 700
      }
    },
    "next_action": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180
    },
    "checked_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
