{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openyggdrasil.local/contracts/graphify_snapshot_from_live_delta.v1.schema.json",
  "title": "OpenYggdrasil Graphify Snapshot From Live Delta v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "snapshot_proof_id",
    "source_delta_id",
    "source_artifact_bundle_id",
    "provider_name",
    "provider_profile",
    "session_ref",
    "source_delta_ref",
    "snapshot_ref",
    "snapshot_manifest",
    "source_delta_refs",
    "safe_evidence_pointer_count",
    "raw_transcript_included",
    "graphify_is_sot",
    "provider_may_answer_from_graphify_alone",
    "canonical_output_allowed",
    "mailbox_receipt_refs",
    "reasoning_lease_isolation_refs",
    "typed_unavailable_surfaces",
    "rerun_condition",
    "evidence_required",
    "claim_scope",
    "decision",
    "readiness_state",
    "checked_at"
  ],
  "properties": {
    "schema_version": {
      "const": "graphify_snapshot_from_live_delta.v1"
    },
    "snapshot_proof_id": {
      "$ref": "#/$defs/id"
    },
    "source_delta_id": {
      "$ref": "#/$defs/id"
    },
    "source_artifact_bundle_id": {
      "$ref": "#/$defs/id"
    },
    "provider_name": {
      "const": "hermes"
    },
    "provider_profile": {
      "$ref": "#/$defs/id"
    },
    "session_ref": {
      "$ref": "#/$defs/ref"
    },
    "source_delta_ref": {
      "$ref": "#/$defs/ref"
    },
    "snapshot_ref": {
      "anyOf": [
        {
          "$ref": "#/$defs/ref"
        },
        {
          "type": "null"
        }
      ]
    },
    "snapshot_manifest": {
      "$ref": "#/$defs/snapshotManifest"
    },
    "source_delta_refs": {
      "$ref": "#/$defs/stringRefs"
    },
    "safe_evidence_pointer_count": {
      "type": "integer",
      "minimum": 0
    },
    "raw_transcript_included": {
      "const": false
    },
    "graphify_is_sot": {
      "const": false
    },
    "provider_may_answer_from_graphify_alone": {
      "const": false
    },
    "canonical_output_allowed": {
      "const": false
    },
    "mailbox_receipt_refs": {
      "$ref": "#/$defs/stringRefs"
    },
    "reasoning_lease_isolation_refs": {
      "$ref": "#/$defs/stringRefs"
    },
    "typed_unavailable_surfaces": {
      "type": "array",
      "maxItems": 8,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/surface"
      }
    },
    "rerun_condition": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 140,
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        {
          "type": "null"
        }
      ]
    },
    "evidence_required": {
      "type": "array",
      "maxItems": 16,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 140,
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "claim_scope": {
      "type": "string",
      "enum": [
        "e2e3_graphify_snapshot_only",
        "full_live_e2e_graphify_candidate",
        "typed_unavailable_not_live_proven",
        "not_claimable"
      ]
    },
    "decision": {
      "type": "string",
      "enum": [
        "e2e3_graphify_snapshot_valid",
        "typed_unavailable_not_live_proven",
        "red_captured"
      ]
    },
    "readiness_state": {
      "type": "string",
      "enum": [
        "ready_for_e2e4",
        "not_ready"
      ]
    },
    "checked_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 420
    },
    "stringRefs": {
      "type": "array",
      "maxItems": 48,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/ref"
      }
    },
    "surface": {
      "type": "string",
      "enum": [
        "graphify_snapshot",
        "mailbox_receipt",
        "reasoning_lease_isolation"
      ]
    },
    "snapshotManifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "manifest_id",
        "source_adapter_schema_version",
        "status",
        "snapshot_role",
        "canonicality",
        "mutation_policy",
        "graph_path",
        "summary_path",
        "graphify_manifest_path",
        "vault_root",
        "summary",
        "freshness",
        "failure",
        "provenance_policy",
        "generated_at"
      ],
      "properties": {
        "schema_version": {
          "const": "graphify_snapshot_manifest.v1"
        },
        "manifest_id": {
          "type": "string",
          "minLength": 1
        },
        "source_adapter_schema_version": {
          "const": "graphify_snapshot_adapter.v1"
        },
        "status": {
          "enum": [
            "available",
            "unavailable"
          ]
        },
        "snapshot_role": {
          "const": "derived_graph_snapshot"
        },
        "canonicality": {
          "const": "non_sot"
        },
        "mutation_policy": {
          "const": "read_only_no_sot_mutation"
        },
        "graph_path": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "summary_path": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "graphify_manifest_path": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "vault_root": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "anyOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "nodes",
                "edges",
                "communities",
                "god_nodes",
                "surprising_connections"
              ],
              "properties": {
                "nodes": {
                  "type": "integer",
                  "minimum": 0
                },
                "edges": {
                  "type": "integer",
                  "minimum": 0
                },
                "communities": {
                  "type": "integer",
                  "minimum": 0
                },
                "god_nodes": {
                  "type": "array"
                },
                "surprising_connections": {
                  "type": "array"
                }
              }
            },
            {
              "type": "null"
            }
          ]
        },
        "freshness": {
          "type": "object"
        },
        "failure": {
          "anyOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "reason_code",
                "message"
              ],
              "properties": {
                "reason_code": {
                  "type": "string",
                  "minLength": 1
                },
                "message": {
                  "type": "string"
                }
              }
            },
            {
              "type": "null"
            }
          ]
        },
        "provenance_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "graphify_is_sot",
            "must_verify_against_sot",
            "raw_session_copy_allowed",
            "provider_may_answer_from_graphify_alone"
          ],
          "properties": {
            "graphify_is_sot": {
              "const": false
            },
            "must_verify_against_sot": {
              "const": true
            },
            "raw_session_copy_allowed": {
              "const": false
            },
            "provider_may_answer_from_graphify_alone": {
              "const": false
            }
          }
        },
        "generated_at": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
