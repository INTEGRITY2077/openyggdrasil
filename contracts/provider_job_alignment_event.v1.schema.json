{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openyggdrasil.local/contracts/provider_job_alignment_event.v1.schema.json",
  "title": "OpenYggdrasil Provider Job Alignment Event v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "event_id",
    "job_id",
    "job_name",
    "declaration_ref",
    "provider_issue_refs",
    "implementation_refs",
    "proof_refs",
    "alignment_state",
    "readiness_state",
    "source_declaration_score",
    "issue_absorption_score",
    "contract_score",
    "implementation_score",
    "executable_proof_score",
    "production_evidence_score",
    "boundary_hygiene_score",
    "overall_alignment_score",
    "blocking_gaps",
    "checked_at"
  ],
  "properties": {
    "schema_version": {
      "const": "provider_job_alignment_event.v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "event_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 220
    },
    "job_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "job_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "declaration_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 260
    },
    "provider_issue_refs": {
      "type": "array",
      "maxItems": 24,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 260
      }
    },
    "implementation_refs": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 260
      }
    },
    "proof_refs": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 260
      }
    },
    "alignment_state": {
      "type": "string",
      "enum": [
        "declared_unimplemented",
        "issue_captured",
        "contract_aligned",
        "runtime_partially_aligned",
        "executable_contract_aligned",
        "production_proven"
      ]
    },
    "readiness_state": {
      "type": "string",
      "enum": [
        "red",
        "partial",
        "aligned"
      ]
    },
    "source_declaration_score": {
      "$ref": "#/$defs/score"
    },
    "issue_absorption_score": {
      "$ref": "#/$defs/score"
    },
    "contract_score": {
      "$ref": "#/$defs/score"
    },
    "implementation_score": {
      "$ref": "#/$defs/score"
    },
    "executable_proof_score": {
      "$ref": "#/$defs/score"
    },
    "production_evidence_score": {
      "$ref": "#/$defs/score"
    },
    "boundary_hygiene_score": {
      "$ref": "#/$defs/score"
    },
    "overall_alignment_score": {
      "$ref": "#/$defs/score"
    },
    "blocking_gaps": {
      "type": "array",
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 160,
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "checked_at": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    }
  },
  "$defs": {
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
